# ──────────────────────────────────────────────────────────────────────────────
# SafeCity SP — Template de Variáveis de Ambiente
#
# Copie este arquivo para .env e preencha com seus valores.
# NUNCA commitar .env com credenciais reais — adicionar a .gitignore.
# ──────────────────────────────────────────────────────────────────────────────

# ─── SUPABASE ─────────────────────────────────────────────────────────────────
# Projeto criado em https://supabase.com

# URL REST do projeto (formato: https://<ref>.supabase.co)
SUPABASE_URL=https://your-project-ref.supabase.co

# Chave service_role — usada APENAS no pipeline backend
# NUNCA expor no frontend ou em repositório público
# Disponível em: Supabase > Project Settings > API > Service role key
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Chave anon — exposta no frontend para dados públicos
# Disponível em: Supabase > Project Settings > API > Anon key
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── Conexão Direta PostgreSQL ────────────────────────────────────────────────
# Usada pelo pipeline Spark para carregar KPIs via SQLAlchemy/psycopg2
# Disponível em: Supabase > Project Settings > Database > Connection string

SUPABASE_DB_HOST=db.your-project-ref.supabase.co
SUPABASE_DB_PORT=5432
SUPABASE_DB_NAME=postgres
SUPABASE_DB_USER=postgres
SUPABASE_DB_PASSWORD=your-database-password-here

# ─── PYSPARK ──────────────────────────────────────────────────────────────────

# Memória alocada para o driver Spark (formato: 2g, 4g, 8g, etc.)
# Recomendação:
#   - 4g  : Máquina com ≤8GB RAM total
#   - 8g  : Máquina com 16GB+ RAM (mais rápido)
# Aumentar memoria para conjuntos de dados > 2GB
SPARK_DRIVER_MEMORY=4g

# ─── PATHS ────────────────────────────────────────────────────────────────────

# Caminho para pasta com os .xlsx brutos da SSP-SP
# Relativo ao spark/ (que fica dentro de ../raw)
RAW_DATA_PATH=../raw

# Caminho onde os checkpoints Parquet serão salvos
# Criado automaticamente se não existir
PARQUET_PATH=../parquet
